{
  "manifest_version": 3,
  "name": "Benzinga Chat Collector",
  "version": "1.1.0",
  "description": "Collect Benzinga Inner Circle chat messages.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.benzinga.com/*", "https://*.netlify.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.benzinga.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Benzinga Collector"
  }
}
